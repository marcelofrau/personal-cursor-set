[Version]
signature="$CHICAGO$"

[DefaultInstall]
CopyFiles = Scheme.Cur, Scheme.Txt
AddReg    = Scheme.Reg

[DestinationDirs]
Scheme.Cur = 10,"%CUR_DIR%"
Scheme.Txt = 10,"%CUR_DIR%"

[Scheme.Reg]
HKCU,"Control Panel\Cursors\Schemes","%SCHEME_NAME%",,"%10%\%CUR_DIR%\%pointer%,%10%\%CUR_DIR%\%help%,%10%\%CUR_DIR%\%work%,%10%\%CUR_DIR%\%busy%,%10%\%CUR_DIR%\%cross%,%10%\%CUR_DIR%\%Text%,%10%\%CUR_DIR%\%Hand%,%10%\%CUR_DIR%\%unavailiable%,%10%\%CUR_DIR%\%Vert%,%10%\%CUR_DIR%\%Horz%,%10%\%CUR_DIR%\%Dgn1%,%10%\%CUR_DIR%\%Dgn2%,%10%\%CUR_DIR%\%move%,%10%\%CUR_DIR%\%alternate%,%10%\%CUR_DIR%\%link%"

[Scheme.Cur]
Shiori normal.ani
Shiori help.ani
Shiori work.ani
Shiori busy.ani
Shiori text.ani
Shiori unavailable.ani
Shiori vert.ani
Shiori horz.ani
Shiori dgn1.ani
Shiori dgn2.ani
Shiori move.ani
Shiori link.ani
Shiori precision.ani
Shiori hand.ani
Shiori alt.ani

[Scheme.Txt]

[Strings]
CUR_DIR       = "Cursors\Shiori Novella Cursor"
SCHEME_NAME   = "Shiori Novella Cursor"
pointer       = "Shiori normal.ani"
help          = "Shiori help.ani"
work          = "Shiori work.ani"
busy          = "Shiori busy.ani"
text          = "Shiori text.ani"
unavailiable  = "Shiori unavailable.ani"
vert          = "Shiori vert.ani"
horz          = "Shiori horz.ani"
dgn1          = "Shiori dgn1.ani"
dgn2          = "Shiori dgn2.ani"
move          = "Shiori move.ani"
link          = "Shiori link.ani"
cross         = "Shiori precision.ani"
hand          = "Shiori hand.ani"
alternate     = "Shiori alt.ani"