[Version]
signature="$CHICAGO$"

[DefaultInstall]
CopyFiles = Scheme.Cur, Scheme.Txt
AddReg    = Scheme.Reg

[DestinationDirs]
Scheme.Cur = 10,"%CUR_DIR%"
Scheme.Txt = 10,"%CUR_DIR%"

[Scheme.Reg]
HKCU,"Control Panel\Cursors\Schemes","%SCHEME_NAME%",,"%10%\%CUR_DIR%\%pointer%,%10%\%CUR_DIR%\%help%,%10%\%CUR_DIR%\%work%,%10%\%CUR_DIR%\%busy%,%10%\%CUR_DIR%\%cross%,%10%\%CUR_DIR%\%Text%,%10%\%CUR_DIR%\%Hand%,%10%\%CUR_DIR%\%unavailiable%,%10%\%CUR_DIR%\%Vert%,%10%\%CUR_DIR%\%Horz%,%10%\%CUR_DIR%\%Dgn1%,%10%\%CUR_DIR%\%Dgn2%,%10%\%CUR_DIR%\%move%,%10%\%CUR_DIR%\%alternate%,%10%\%CUR_DIR%\%link%"

[Scheme.Cur]
Kuro normal.ani
Kuro help.ani
Kuro work.ani
Kuro busy.ani
Kuro text.ani
Kuro unavailable.ani
Kuro vert.ani
Kuro horz.ani
Kuro dgn1.ani
Kuro dgn2.ani
Kuro move.ani
Kuro link.ani
Kuro precision.ani
Kuro hand.ani
Kuro alt.ani

[Scheme.Txt]

[Strings]
CUR_DIR       = "Cursors\Kuro Cursor"
SCHEME_NAME   = "Kuro Cursor"
pointer       = "Kuro normal.ani"
help          = "Kuro help.ani"
work          = "Kuro work.ani"
busy          = "Kuro busy.ani"
text          = "Kuro text.ani"
unavailiable  = "Kuro unavailable.ani"
vert          = "Kuro vert.ani"
horz          = "Kuro horz.ani"
dgn1          = "Kuro dgn1.ani"
dgn2          = "Kuro dgn2.ani"
move          = "Kuro move.ani"
link          = "Kuro link.ani"
cross         = "Kuro precision.ani"
hand          = "Kuro hand.ani"
alternate     = "Kuro alt.ani"